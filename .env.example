REDIS_URL=redis://redis:6379/0
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_WINDOW_SECONDS=60
CIRCUIT_COOLDOWN_SECONDS=30

# Deep classifier (ML-based prompt injection detection)
# Set to False to disable and use fast_filter only
DEEP_CLASSIFIER_ENABLED=True
DEEP_CLASSIFIER_MODEL=protectai/deberta-v3-base-prompt-injection-v2
DEEP_CLASSIFIER_THRESHOLD=0.5

# Fallback routing (safe response for blocked requests)
# "static" = fixed message (default, no API key needed)
# "model" = call Groq/OpenRouter (requires FALLBACK_MODEL_API_KEY)
FALLBACK_STRATEGY=static
FALLBACK_STATIC_MESSAGE=This request could not be processed safely. Please rephrase and try again.
FALLBACK_MODEL_PROVIDER=groq
FALLBACK_MODEL_NAME=llama-3.1-8b-instant
FALLBACK_MODEL_API_KEY=
